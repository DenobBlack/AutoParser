<Page x:Class="AutoParser.Pages.CreateTOPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AutoParser.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateTOPage">

    <Grid Grid.Column="2" Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0" x:Name="HistoryRow"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CAR + SERVICE -->

        <Border Background="White"
        CornerRadius="10"
        Padding="25"
        Margin="0,0,0,20"
        BorderBrush="#E5E7EB"
        BorderThickness="1" Cursor="">

            <StackPanel>

                <TextBlock Text="Создание технического обслуживания"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0 0 0 15"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="10">
                        <TextBlock Text="Автомобиль"
                           FontWeight="SemiBold"
                           Margin="0 0 0 5"/>
                        <ComboBox Height="36" KeyUp="CarComboBox_KeyUp" x:Name="CarComboBox" DisplayMemberPath="DisplayName" IsTextSearchEnabled="False" IsEditable="True" StaysOpenOnEdit="True" SelectionChanged="CarComboBox_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="Тип ТО"
                           FontWeight="SemiBold"
                           Margin="0 0 0 5"/>
                        <ComboBox Height="36" x:Name="ServiceTypeComboBox" DisplayMemberPath="Name" SelectionChanged="ServiceTypeComboBox_SelectionChanged"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                    Content="Создать ТО"
                    Style="{StaticResource ModernButton}"
                    Width="170"
                    Height="42"
                    Click="CreateOrder_Click"          
                    />

                </Grid>
                <StackPanel>

                    <DockPanel>

                        <TextBox
    x:Name="PartSearchBox"
    Width="300"
    Height="35"
    VerticalAlignment="Center"
    TextChanged="PartSearchBox_TextChanged"
    Margin="10"/>

                        <Button
    Content="Добавить"
    Width="170"
    Height="35"
    Click="AddPart_Click"
    Style="{StaticResource ModernButton}"/>

                    </DockPanel>

                    <ListBox
x:Name="PartsSearchList"
Height="120"
            MouseDoubleClick="PartsSearchList_MouseDoubleClick"
Visibility="Collapsed"
DisplayMemberPath="DisplayName"/>

                </StackPanel>

            </StackPanel>

        </Border>


        <!-- TABLE -->

        <DataGrid Grid.Row="2"
          x:Name="PartsGrid"
          AutoGenerateColumns="False"
          Background="White"
          BorderThickness="1"
          BorderBrush="#E5E7EB"
                      CellEditEnding="PartsGrid_CellEditEnding"
          RowHeight="35"
          CanUserAddRows="False"
          HeadersVisibility="Column"
          GridLinesVisibility="None"
          AlternatingRowBackground="#F9FAFB" KeyDown="PartsGrid_KeyDown">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Деталь"
                            Binding="{Binding Name}"
                            Width="*"/>

                <DataGridTextColumn Header="Кол-во"
                    Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                    Width="100"/>

                <DataGridTextColumn Header="Цена"
                            Binding="{Binding Price}"
                            Width="120"/>
                <DataGridTemplateColumn Header="" Width="60">

                    <DataGridTemplateColumn.CellTemplate>

                        <DataTemplate>

                            <Button
                Content="✖"
                Width="30"
                Height="25"
                Background="#EF4444"
                Foreground="White"
                BorderThickness="0"
                FontWeight="Bold"
                Click="RemovePart_Click"/>

                        </DataTemplate>

                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>
            </DataGrid.Columns>

        </DataGrid>
        <DataGrid Grid.Row="3"
          x:Name="HistoryGrid"
          Height="150"
          Margin="0,15,0,102"
          AutoGenerateColumns="False"
          Background="White"
          Visibility="Collapsed"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          BorderBrush="#E5E7EB"
          BorderThickness="1" Grid.RowSpan="3">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Дата"
                            Binding="{Binding Date}"
                            Width="150"/>

                <DataGridTextColumn Header="Тип ТО"
                            Binding="{Binding ServiceName}"
                            Width="200"/>

                <DataGridTextColumn Header="Пробег"
                            Binding="{Binding Mileage}"
                            Width="120"/>

                <DataGridTextColumn Header="Сумма"
                            Binding="{Binding Total}"
                            Width="120"/>

            </DataGrid.Columns>

        </DataGrid>
        <!-- TOTAL -->

        <Border Grid.Row="5"
        Background="White"
        BorderBrush="#E5E7EB"
        BorderThickness="1"
        Padding="20"
        CornerRadius="10"
        Margin="0,15,0,0">

            <DockPanel>

                <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Right">

                    <TextBlock Text="Итого:"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="10"/>

                    <TextBlock Text="0 ₽"
                       FontSize="20"
                       FontWeight="Bold"
                       x:Name="TotalText"
                       VerticalAlignment="Center"
                       Foreground="#EB0A1E"
                       Margin="10"/>

                    <Button Content="Экспорт в 1С"
                    Style="{StaticResource ModernButton}"
                    Width="150"
                    Height="40"
                                HorizontalAlignment="Right"
                    Margin="10"/>
                    <Button Content="История ТО"
                                  Style="{StaticResource ModernButton}"
        Width="120"
        Height="42"
        Click="ToggleHistory"/>
                </StackPanel>

            </DockPanel>

        </Border>

    </Grid>

</Page>
