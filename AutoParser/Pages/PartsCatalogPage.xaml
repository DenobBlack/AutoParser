<Page x:Class="AutoParser.Pages.PartsCatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AutoParser.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PartsCatalogPage" >

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Style="{StaticResource CardStyle}">

            <StackPanel>

                <TextBlock Text="Каталог деталей"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0 0 0 15"/>

                <DockPanel>

                    <TextBox x:Name="SearchBox"
                             Width="300"
                             Height="35"
                             Margin="0 0 10 0"
                             TextChanged="SearchBox_TextChanged"/>

                    <Button Content="Добавить деталь"
                            Width="160"
                            Height="35"
                            Style="{StaticResource ModernButton}"
                            Click="AddPart_Click"/>

                </DockPanel>

            </StackPanel>

        </Border>

        <!-- TABLE -->

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}">

            <DataGrid x:Name="PartsGrid"
                      MouseDoubleClick="PartsGrid_MouseDoubleClick"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      RowHeight="35"
                      KeyDown="PartsGrid_KeyDown">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Название"
                                        Binding="{Binding Name}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Каталожный номер"
                                        Binding="{Binding PartNumber}"
                                        Width="200"/>

                    <DataGridTextColumn Header="Цена"
                                        Binding="{Binding Price}"
                                        Width="120"/>
                    <DataGridTemplateColumn Header="" Width="60">

                        <DataGridTemplateColumn.CellTemplate>

                            <DataTemplate>

                                <Button
   Content="✖"
   Width="30"
   Height="25"
   Background="#EF4444"
   Foreground="White"
   BorderThickness="0"
   FontWeight="Bold"
   Click="RemovePart_Click"/>

                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>
                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</Page>
